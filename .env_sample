# ML Heating configuration Sample
# Copy this file to .env and set your actual values.
# Keep tokens and sensitive information secret; do NOT commit your .env file to version control.

# --- Home Assistant ---
# Base URL of your Home Assistant instance (e.g., http://homeassistant.local:8123)
HASS_URL=https://home-assistant.example.com

# A Long-Lived Access Token from your Home Assistant profile page.
HASS_TOKEN=YOUR_HOME_ASSISTANT_TOKEN

# --- InfluxDB ---
# URL of your InfluxDB instance, including the protocol and port.
INFLUX_URL=https://influxdb.example.com:8086

# An InfluxDB API token with read AND write access.
# Read access is required for INFLUX_BUCKET (historical sensor data).
# Write access is required for INFLUX_FEATURES_BUCKET (ML metrics export).
# If write access is missing, InfluxDB exports will fail with 401 Unauthorized.
INFLUX_TOKEN=YOUR_INFLUXDB_TOKEN

# The InfluxDB organization and bucket where your Home Assistant data is stored.
INFLUX_ORG=your-org
INFLUX_BUCKET=home_assistant/autogen

# --- Model and State ---
# Absolute path to store the unified thermal state.
# When SHADOW_MODE=true, the runtime automatically appends _shadow before the
# file extension to keep the shadow deployment isolated.
# For Home Assistant addon deployments: use /config/ml_heating/ to store the
# file in the HA configuration folder (accessible via File Editor add-on,
# same folder as configuration.yaml). The /data/ path is addon-internal only.
UNIFIED_STATE_FILE=/opt/ml_heating/unified_thermal_state.json
# Cooling-specific state file (separate from heating to avoid cross-contamination).
UNIFIED_STATE_FILE_COOLING=/opt/ml_heating/unified_thermal_state_cooling.json

# --- Script Behavior ---
# Number of historical steps to use as features for the model.
HISTORY_STEPS=6

# The duration of each historical step in minutes.
HISTORY_STEP_MINUTES=10

# How many 5-minute steps into the future the model should predict.
# Example: 24 means 24 * 5min = 120 minutes ahead.
PREDICTION_HORIZON_STEPS=24

# The number of hours of historical data to use for initial training.576
TRAINING_LOOKBACK_HOURS=576

# --- Home Assistant Entity IDs ---
# These must match the entity IDs in your Home Assistant instance.

# An input_number or sensor that holds the target indoor temperature.
TARGET_INDOOR_TEMP_ENTITY_ID=input_number.soll_rt

# The primary indoor temperature sensor.
#INDOOR_TEMP_ENTITY_ID=sensor.rt_mittelwert_mean
INDOOR_TEMP_ENTITY_ID=sensor.rt_mittelwert

# --- Additional Indoor Sensors ---
# Living room temperature sensor (used for fireplace analysis only)
LIVING_ROOM_TEMP_ENTITY_ID=sensor.rt_wz

# The heat pump's outlet temperature sensor.
ACTUAL_OUTLET_TEMP_ENTITY_ID=sensor.nibe_bt2_supply_temp_s1

# The heat pump's inlet (return) temperature sensor.
INLET_TEMP_ENTITY_ID=sensor.nibe_eb100_ep14_bt3_return_temp

# The heat pump's flow rate sensor (L/min).
FLOW_RATE_ENTITY_ID=input_number.hp_current_flow_rate

# The heat pump's power consumption sensor (Watts).
POWER_CONSUMPTION_ENTITY_ID=sensor.nibe_el_leistung

# Specific heat capacity of the fluid (kJ/kg·K). Default is 4.186 for water.
SPECIFIC_HEAT_CAPACITY=4.186

# The entity this script will write its calculated target outlet temperature to.
# When SHADOW_MODE=true, the published HA output entity automatically becomes
# this entity id with _shadow appended.
TARGET_OUTLET_TEMP_ENTITY_ID=sensor.ml_vorlauftemperatur

# The target outlet temperature that was actually set (by model or heat curve).
# Used for learning in both active and shadow modes. This allows the model to
# learn correctly even when running in shadow mode (not controlling the heating).
# Example shadow deployment mapping:
# - TARGET_OUTLET_TEMP_ENTITY_ID=sensor.ml_vorlauftemperatur
# - ACTUAL_TARGET_OUTLET_TEMP_ENTITY_ID=sensor.ml_vorlauftemperatur
# - SHADOW_MODE=true
# Result: the model learns from sensor.ml_vorlauftemperatur and publishes its
# own recommendation to sensor.ml_vorlauftemperatur_shadow.
# ACTUAL_TARGET_OUTLET_TEMP_ENTITY_ID=sensor.nibe_calc_supply_s1
ACTUAL_TARGET_OUTLET_TEMP_ENTITY_ID=sensor.ml_vorlauftemperatur

# A binary sensor that is 'on' when Domestic Hot Water (DHW) is being heated.
DHW_STATUS_ENTITY_ID=binary_sensor.warmwassermodus

# A binary sensor that is 'on' during a defrost cycle.
DEFROST_STATUS_ENTITY_ID=binary_sensor.defrost_wp

# A binary sensor that is 'on' during a DHW tank disinfection cycle.
DISINFECTION_STATUS_ENTITY_ID=binary_sensor.warmwassermodus

# A binary sensor that is 'on' when the DHW boost heater is active.
DHW_BOOST_HEATER_STATUS_ENTITY_ID=binary_sensor.warmwassermodus

# A sensor or helper (e.g., input_boolean) that indicates if a TV or other significant heat source is on.
TV_STATUS_ENTITY_ID=input_boolean.tv_an

# A binary sensor that is 'on' when the fireplace is active.
FIREPLACE_STATUS_ENTITY_ID=binary_sensor.kamin_an

# A sensor that provides the average temperature of rooms not affected by the fireplace.
AVG_OTHER_ROOMS_TEMP_ENTITY_ID=sensor.rt_mittelwert

# The outdoor temperature sensor, preferably compensated or near the heat pump.
#OUTDOOR_TEMP_ENTITY_ID=sensor.stat_at
OUTDOOR_TEMP_ENTITY_ID=sensor.nibe_bt1_outdoor_temperature

# The climate entity for your heating system, used to check if it's in 'heat' or 'auto' mode.
HEATING_STATUS_ENTITY_ID=sensor.betriebsmodus_wp

# An external weather forecast temperature sensor (e.g., from OpenWeatherMap).
OPENWEATHERMAP_TEMP_ENTITY_ID=weather.home

# --- PV (Solar) Power Entity ID ---
# A single aggregated sensor for total PV power generation.
#PV_POWER_ENTITY_ID=sensor.evcc_pv_power
#PV_POWER_ENTITY_ID=sensor.stat_pv_power_mean
PV_POWER_ENTITY_ID=sensor.pv_leistung_gefiltert

# Home Assistant input_number for dynamic solar correction in percent.
# Example: 100 = no reduction, 50 = half PV influence, 30 = strong shading.
SOLAR_CORRECTION_ENTITY_ID=input_number.ml_heating_solar_correction

# Fallback and clamping for solar correction input_number (in percent)
SOLAR_CORRECTION_DEFAULT_PERCENT=100.0
SOLAR_CORRECTION_MIN_PERCENT=0.0
SOLAR_CORRECTION_MAX_PERCENT=100.0


# The Home Assistant sensor that provides today's PV forecast with attributes
# 'watts' (15-min samples) used to compute hourly forecast means.
PV_FORECAST_ENTITY_ID=sensor.ml_pv_forecast_watts

# --- Advanced Features & Tuning ---
# Enable time-delayed learning for external heat sources
ENABLE_MULTI_LAG_LEARNING=true
PV_LAG_STEPS=4
FIREPLACE_LAG_STEPS=4
TV_LAG_STEPS=2

# Enable seasonal adaptation (learning from long-term trends)
ENABLE_SEASONAL_ADAPTATION=true
SEASONAL_LEARNING_RATE=0.01
MIN_SEASONAL_SAMPLES=100

# Enable learning during summer (HVAC off) for cleaner signal
ENABLE_SUMMER_LEARNING=true

# Hybrid Learning Strategy
HYBRID_LEARNING_ENABLED=true
STABILITY_CLASSIFICATION_ENABLED=true
HIGH_CONFIDENCE_WEIGHT=1.0
LOW_CONFIDENCE_WEIGHT=0.3

# Prediction Metrics Tracking
PREDICTION_METRICS_ENABLED=true
METRICS_WINDOW_1H=12
METRICS_WINDOW_6H=72
METRICS_WINDOW_24H=288
PREDICTION_ACCURACY_THRESHOLD=0.3
MAE_ENTITY_ID=sensor.ml_model_mae
RMSE_ENTITY_ID=sensor.ml_model_rmse

# Trajectory Prediction
TRAJECTORY_PREDICTION_ENABLED=true
WEATHER_FORECAST_INTEGRATION=true
PV_FORECAST_INTEGRATION=true
SOLAR_CORRECTION_ENABLED=true
CLOUD_COVER_CORRECTION_ENABLED=true
CLOUD_CORRECTION_MIN_FACTOR=0.1
OVERSHOOT_DETECTION_ENABLED=true

# InfluxDB bucket for generated ML metrics and feature storage.
# When SHADOW_MODE=true, the runtime writes to this bucket with _shadow
# appended. Reads from INFLUX_BUCKET stay unchanged.
INFLUX_FEATURES_BUCKET=ml_heating_features

# Export adaptive learning metrics to InfluxDB every N learning cycles.
# Home Assistant sensor metrics remain real-time and update every cycle.
INFLUX_METRICS_EXPORT_INTERVAL_CYCLES=5

# --- Debugging ---
# Set to "1" to enable detailed logging of feature vectors and model decisions.
# Set to "0" or remove for normal operation.
DEBUG=1

# --- Model Confidence ---
# The physics model uses learning_confidence in range (0.1..10.0], where higher values mean
# better learning performance and parameter stability. The system falls back to traditional
# heat curve when confidence drops below threshold.
# Current scale: 0.1=poor, 2.0=fair, 3.0=good, 4.0=excellent, 5.0+=outstanding
# Recommended: 2.0 for safety fallback while allowing ML to operate normally
CONFIDENCE_THRESHOLD=2.0

# --- Trajectory Prediction ---
# Number of hours to predict in trajectory optimization.
TRAJECTORY_STEPS=4

# The time in minutes between each full cycle of learning and prediction.
CYCLE_INTERVAL_MINUTES=10

# The maximum allowable integer change (in degrees) for the outlet temperature
# setpoint in a single cycle. This prevents abrupt changes and is required as
# the heatpump may only accept full degrees.
MAX_TEMP_CHANGE_PER_CYCLE=2

# Maximum minutes to wait during the grace period after blocking ends.
GRACE_PERIOD_MAX_MINUTES=15

# How often (seconds) to poll blocking entities during the idle period.
# A value of 60 means we check the blocking state once per minute. Increase
# this value to reduce HA polling load, or lower it to react faster to
# defrost/DHW transitions.
BLOCKING_POLL_INTERVAL_SECONDS=60

# --- Absolute clamp settings for ML-proposed outlet temp ---
# Override these in your .env to change the allowed ML output range.
# Any ML-proposed temp will be clipped to [CLAMP_MIN_ABS, CLAMP_MAX_ABS].
CLAMP_MIN_ABS=18.0
CLAMP_MAX_ABS=35.0

# --- Cooling Mode Configuration ---
# When HEATING_STATUS_ENTITY_ID reports "cool", the ML switches to cooling
# mode. In cooling mode the outlet temp is BELOW room temperature.
# COOLING_CLAMP_MIN_ABS: Hard HP shutdown limit (HP stops at this temp).
# COOLING_CLAMP_MAX_ABS: Upper bound — near room temp, least aggressive.
# MIN_COOLING_DELTA_K: Minimum inlet–outlet delta for HP to operate (K).
# COOLING_SHUTDOWN_MARGIN_K: Safety margin above shutdown limit to prevent
#   short-cycling (HP restarts too quickly after hitting the limit).
COOLING_CLAMP_MIN_ABS=18.0
COOLING_CLAMP_MAX_ABS=24.0
MIN_COOLING_DELTA_K=2.0
COOLING_SHUTDOWN_MARGIN_K=1.0

# --- Optional: Model Metrics Entity IDs ---
# These entities are automatically created in Home Assistant for monitoring.
# You can override the defaults if needed.
# CONFIDENCE_ENTITY_ID=sensor.ml_model_confidence
# MAE_ENTITY_ID=sensor.ml_model_mae
# RMSE_ENTITY_ID=sensor.ml_model_rmse

# --- Multi-Lag External Source Learning ---
# Enable time-delayed learning for PV, fireplace, and TV.
# When enabled, the model learns how these heat sources affect indoor
# temperature with delays (e.g., PV warming peaks 60-90min after production).
ENABLE_MULTI_LAG_LEARNING=true

# Number of lag steps (30min each) to track for each source:
# - PV: 4 lags = track 30, 60, 90, 120min delays
# - Fireplace: 4 lags = immediate, 30, 60, 90min
# - TV: 2 lags = immediate, 30min
PV_LAG_STEPS=4
FIREPLACE_LAG_STEPS=4
TV_LAG_STEPS=2

# --- Seasonal Adaptation ---
# Enable automatic seasonal learning using cos/sin modulation.
# This eliminates the need for manual recalibration between winter and summer.
# The model learns how external sources vary seasonally (e.g., windows open
# in summer reduce PV warming effect by ~50%).
ENABLE_SEASONAL_ADAPTATION=true

# Learning rate for seasonal parameters (lower = more stable, slower adapt)
SEASONAL_LEARNING_RATE=0.01

# Minimum samples before seasonal learning starts
MIN_SEASONAL_SAMPLES=100

# --- Summer Learning ---
# Enable learning from periods when HVAC is off (typically summer).
# This provides cleaner signal for external source effects without
# heating interference. Improves PV and TV coefficients significantly.
ENABLE_SUMMER_LEARNING=true

# --- Shadow Mode ---
# Set to "true" to run a dedicated shadow deployment beside the live controller.
# When enabled:
# - ML learns from the live ACTUAL_TARGET_OUTLET_TEMP_ENTITY_ID and normal
#   history bucket, but publishes its own HA outputs with an added _shadow
#   suffix (for example sensor.ml_vorlauftemperatur_shadow)
# - Generated ML metrics are written to ${INFLUX_FEATURES_BUCKET}_shadow
# - The unified thermal state file is isolated automatically via an added
#   _shadow suffix before the file extension
# - The live heating setpoint is not controlled by this deployment
# Dynamic shadow via ML_HEATING_CONTROL_ENTITY_ID=off keeps runtime shadow
# behavior but does not create a separate _shadow namespace.
SHADOW_MODE=false

# --- ML Heating Control Entity ---
# Home Assistant input_boolean to enable/disable ML control dynamically.
# - When ON: ML actively controls heating (Active Mode)
# - When OFF: Runtime shadow mode is activated (ML observes only)
# - Note: This does not rename entities or buckets; only SHADOW_MODE=true
#   creates the separate _shadow deployment namespace
# Create in HA with: input_boolean.ml_heating
ML_HEATING_CONTROL_ENTITY_ID=input_boolean.ml_heating

# --- Thermal Equilibrium Model Parameters ---
# Core thermal physics parameters for the thermal equilibrium model.
# These parameters control the physics-based calculations and can be tuned
# for different building characteristics and testing scenarios.

# Core Thermal Properties (Priority 1 - Critical for Model Behavior)
# Default values are calibrated baseline parameters — used when no
# calibration file or unified thermal state file is available.
THERMAL_TIME_CONSTANT=4.390554703745845
# Building thermal response time constant (hours)
EQUILIBRIUM_RATIO=0.17
# Equilibrium ratio (dimensionless)
TOTAL_CONDUCTANCE=0.8
# Total thermal conductance (1/hour)
HEAT_LOSS_COEFFICIENT=0.1245214561975565
# Heat loss rate per degree difference (1/hour)
OUTLET_EFFECTIVENESS=0.9526723072021629
# Heat pump outlet efficiency (dimensionless)
SLAB_TIME_CONSTANT_HOURS=3.19
# UFH slab (Estrich) first-order thermal time constant (hours)
SOLAR_LAG_MINUTES=45.0
# Effective delay/smoothing window for solar gain (minutes)
OUTDOOR_COUPLING=0.3
# Outdoor temperature influence factor
THERMAL_BRIDGE_FACTOR=0.1
# Thermal bridging losses

# External Heat Source Weights (Priority 2 - Multi-Source Testing)
# Only includes heat sources with actual sensors in your system
PV_HEAT_WEIGHT=0.0020704649305198215
# PV power heating contribution (°C/W)
FIREPLACE_HEAT_WEIGHT=0.387
# Fireplace heating contribution (°C)
TV_HEAT_WEIGHT=0.35
# TV/electronics heating contribution (°C)
DELTA_T_FLOOR=2.3
# Heat-pump loop delta-T floor used by the HP channel (°C)
FP_DECAY_TIME_CONSTANT=3.9144707244638868
# Fireplace channel heat decay time constant (hours)
ROOM_SPREAD_DELAY_MINUTES=18.0
# Fireplace channel room-spread delay (minutes)

# Adaptive Learning Parameters (Priority 3 - Advanced Tuning)
ADAPTIVE_LEARNING_RATE=0.01        
# Base learning rate (reduced from 0.003 for stability - 6x slower drift)
MIN_LEARNING_RATE=0.001          
# Minimum learning rate (reduced from 0.0005 for stability)
MAX_LEARNING_RATE=0.01          
# Maximum learning rate (reduced from 0.005 for stability)
LEARNING_CONFIDENCE=3.0             
# Initial learning confidence
RECENT_ERRORS_WINDOW=10
# Error analysis window size


# --- Hybrid Learning Strategy (Phase 2 Enhancement) ---
# Enable intelligent learning phase classification with weighted periods
HYBRID_LEARNING_ENABLED=true
STABILITY_CLASSIFICATION_ENABLED=true
HIGH_CONFIDENCE_WEIGHT=1.0          
# Weight for stable periods (high confidence learning)
LOW_CONFIDENCE_WEIGHT=0.3           
# Weight for controlled transitions (low confidence learning)
LEARNING_PHASE_SKIP_WEIGHT=0.0      
# Weight for chaotic periods (skip learning)

# --- MAE/RMSE Tracking System (Phase 2 Enhancement) ---
# Enable comprehensive prediction accuracy tracking
PREDICTION_METRICS_ENABLED=true
METRICS_WINDOW_1H=12                
# 1 hour window (12 x 5min samples)
METRICS_WINDOW_6H=72                
# 6 hour window (72 x 5min samples)
METRICS_WINDOW_24H=288              
# 24 hour window (288 x 5min samples)
PREDICTION_ACCURACY_THRESHOLD=0.3   
# °C threshold for accuracy classification

# --- Trajectory Prediction Enhancement (Phase 2) ---
# Advanced trajectory prediction with forecast integration
# CRITICAL FOR UNDERFLOOR: Forecast integration essential for slow thermal response
TRAJECTORY_PREDICTION_ENABLED=true
WEATHER_FORECAST_INTEGRATION=true   
# Use weather forecasts in trajectory prediction - ESSENTIAL for underfloor
PV_FORECAST_INTEGRATION=true        
# Use PV forecasts in trajectory prediction - ESSENTIAL for underfloor
OVERSHOOT_DETECTION_ENABLED=true    
# Enable trajectory-based overshoot detection

# --- Historical Calibration System (Phase 0) ---
# Physics-based historical parameter optimization
CALIBRATION_BASELINE_FILE=/data/calibrated_baseline.json
STABILITY_TEMP_CHANGE_THRESHOLD=0.1 
# °C change threshold for stability filtering
MIN_STABLE_PERIOD_MINUTES=30        
# Minimum duration for stable periods
OPTIMIZATION_METHOD=L-BFGS-B        
# Scipy optimization method

# Indoor temperature ceiling for PV calibration.
# Periods with indoor_temp >= this value are excluded from PV calibration
# because automated blinds likely closed, blocking solar gain while PV stays
# high on the roof. Set just below your blind trigger threshold.
PV_CALIBRATION_INDOOR_CEILING=23.0

# --- Delta Temperature Forecast Calibration ---
# Local weather forecast calibration using temperature offset
ENABLE_DELTA_FORECAST_CALIBRATION=true 
# Enable delta calibration using local temperature offset
DELTA_CALIBRATION_MAX_OFFSET=10.0      
# Maximum allowed offset (°C) for safety

# --- Learning History Sizes ---
# Number of prediction records to keep in memory (and saved to state JSON)
MAX_PREDICTION_HISTORY=700
# Number of parameter update records to keep in memory (and saved to state JSON)
MAX_PARAMETER_HISTORY=700

# --- Indoor Trend Protection ---
# Prevents HLC/OE from drifting when indoor temp moves due to setpoint changes
# or other transients — catches the 0..10°C outdoor case missed by cold-weather protection.
#
# COOLING (indoor falling): dampen HLC-reduction and OE-increase
# °C/60min — indoor falling faster than this fires the cooling guard
INDOOR_COOLING_TREND_THRESHOLD=-0.05
# Factor applied to the update when cooling guard fires (0.3 = allow 30% through)
INDOOR_COOLING_DAMPING_FACTOR=0.3
#
# WARMING (indoor rising): dampen HLC-increase and OE-decrease
# °C/60min — indoor rising faster than this fires the warming guard
INDOOR_WARMING_TREND_THRESHOLD=0.10
# Factor applied to the update when warming guard fires (0.3 = allow 30% through)
INDOOR_WARMING_DAMPING_FACTOR=0.3


# --- Heat Source Channel Architecture (Phase 2-4) ---
# Enable decomposed heat-source learning with independent channels for
# heat pump, solar/PV, fireplace, and TV. Each channel has its own learnable
# parameters and isolated prediction history, preventing cross-contamination
# of learned parameters (e.g., fireplace heat no longer misattributed to
# outlet effectiveness).
# When enabled:
#   - HeatPumpChannel learns OE, slab τ only from clean cycles (no FP, low PV)
#   - SolarChannel learns PV weight, solar lag only during daytime (PV > 500W)
#   - FireplaceChannel learns FP heat output, decay τ only when FP active
#   - TVChannel learns TV heat weight only when TV on
#   - AdaptiveFireplaceLearning is disabled inside EnhancedModelWrapper
# Set to "false" to disable channel decomposition and keep the legacy
# AdaptiveFireplaceLearning fireplace path.
ENABLE_HEAT_SOURCE_CHANNELS=true

# Enable proportional mixed-source attribution when multiple heat sources are
# active in the same cycle. When false, routing falls back to legacy single-
# source attribution behavior. Recommended to enable only during shadow-mode
# rollout first.
ENABLE_MIXED_SOURCE_ATTRIBUTION=false

# Optional channel startup overrides for additional heat source channels.
# FP_HEAT_OUTPUT_KW=5.0
# SOLAR_DECAY_TAU_HOURS=0.5
# CLOUD_FACTOR_EXPONENT=1.0

